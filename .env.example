# Required: Hugging Face token for diarization model access
HF_TOKEN=YOUR_HF_TOKEN_HERE

# Optional variables below are pre-set to their defaults. Uncomment and edit to override.

# Optional: Inference device (default: cuda)
# DEVICE=cuda

# Optional: Model compute precision (default: float16)
# COMPUTE_TYPE=float16

# Optional: Transcription batch size (default: 16)
# BATCH_SIZE=16

# Optional: Default transcription model (default: medium.en)
# Choices: tiny.en, base.en, small.en, medium.en, large-v2, large-v3, turbo
# DEFAULT_MODEL=medium.en
